{
  "name": "capacity-exchange-sdk",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "check": "eslint . && prettier --check .",
    "fix": "prettier --write . && eslint . --fix",
    "check-client": "bun scripts/check-openapi-schema.ts",
    "regenerate-client": "bun scripts/regenerate-openapi-schema.ts && bun run --filter '@sundaeswap/capacity-exchange-client' regenerate-client",
    "publish:ci": "bun run --filter '@sundaeswap/capacity-exchange-*' publish:prod"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "bun": ">=1.1.0"
  },
  "workspaces": [
    "apps/*",
    "apps/demo/contracts",
    "packages/*",
    "examples/*"
  ],
  "overrides": {
    "whatwg-url": "14.1.1",
    "tr46": "5.1.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^25.5.2",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "fast-diff": "^1.3.0",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.21.0",
    "vite-plugin-node-polyfills": "^0.24.0"
  }
}
