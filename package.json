{
  "name": "capacity-exchange-sdk",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "check": "eslint . && prettier --check .",
    "fix": "prettier --write . && eslint . --fix",
    "check-client": "bun scripts/check-openapi-schema.ts",
    "regenerate-client": "bun scripts/regenerate-openapi-schema.ts && bun run --filter '@sundaeswap/capacity-exchange-client' regenerate-client",
    "compile": "COMPACTC_VERSION=0.30.0 bunx fetch-compactc && bun run --filter '*' compile",
    "publish:ci": "bun run --filter '@sundaeswap/capacity-exchange-*' publish:prod"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "bun": ">=1.1.0"
  },
  "workspaces": [
    "apps/*",
    "apps/demo/contracts",
    "packages/*",
    "examples/*"
  ],
  "overrides": {
    "whatwg-url": "14.1.1",
    "tr46": "5.1.1"
  },
  "devDependencies": {
    "@capacity-exchange/archive-tools": "workspace:^",
    "@sundaeswap/capacity-exchange-core": "workspace:^",
    "@sundaeswap/capacity-exchange-nodejs": "workspace:^",
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.39.5",
    "@midnight-ntwrk/midnight-js-compact": "4.1.1",
    "@types/node": "^25.9.5",
    "commander": "^14.0.3",
    "concurrently": "^9.2.4",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "fast-diff": "^1.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "typescript-eslint": "^8.65.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  }
}
