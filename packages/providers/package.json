{
  "name": "@sundaeswap/capacity-exchange-providers",
  "version": "1.3.0",
  "description": "Capacity Exchange providers for midnight transactions",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "bun run --filter '@sundaeswap/capacity-exchange-client' build && bun run --filter '@sundaeswap/capacity-exchange-core' build",
    "build": "tsc && tsc --noEmit -p tests/tsconfig.json",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "publish:prod": "bun publish --tolerate-republish"
  },
  "dependencies": {
    "@capacity-exchange/registry": "1.0.0",
    "@sundaeswap/capacity-exchange-client": "1.1.0",
    "@sundaeswap/capacity-exchange-core": "1.1.0",
    "@midnight-ntwrk/midnight-js-types": "4.0.1",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0"
  },
  "peerDependencies": {
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0"
  },
  "devDependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "@eslint/js": "^9.39.2",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-types": "4.0.1",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@types/node": "^25.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
