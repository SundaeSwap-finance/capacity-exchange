# Midnight Network
TOOLKIT_VERSION=0.18.1-ledger-61-support
MIDNIGHT_NETWORK=preview
NODE_URL=http://rpc.preview.midnight.network
NODE_WS_URL=wss://rpc.preview.midnight.network
INDEXER_URL=http://indexer.preview.midnight.network/api/v3/graphql
INDEXER_WS_URL=wss://indexer.preview.midnight.network/api/v3/graphql/ws
PROOF_SERVER_URL=https://lace-proof-pub.preview.midnight.network

# Wallet
# Path to hex encoded seed
#WALLET_SEED_FILE=wallet-seed.hex.example
# Path to mnemonic file (mutually exclusive with seed hex)
WALLET_MNEMONIC_FILE=wallet-mnemonic.txt

# Server
PORT=3000
LOG_LEVEL=info

# Offer Management
OFFER_TTL_SECONDS=60
