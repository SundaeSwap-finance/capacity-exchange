# Server
PORT=3000
LOG_LEVEL=info

# Logging
# Set to "dev" for pretty-printed logs (default: structured JSON)
NODE_ENV=dev
# If set, logs to a file instead of stdout. if NODE_ENV is "dev", this is ignored
#LOG_FILE=/var/log/capacity-exchange/server.log

# Offer Management
QUOTE_TTL_SECONDS=10
OFFER_TTL_SECONDS=60
# In dev, generated by `task deploy` and passed by Taskfile.
# In production, set explicitly:
#PRICE_CONFIG_FILE=price-config.mainnet.json

# Proof server (defaults to network-specific public endpoint; override for local/production)
#PROOF_SERVER_URL=http://127.0.0.1:6300

# Wallet
# In dev, the server finds wallet-mnemonic.{network}.txt by walking up from cwd.
# In production (mainnet), set one of these explicitly:
#WALLET_MNEMONIC_FILE=path/to/mnemonic.txt
#WALLET_SEED_FILE=path/to/seed.hex
# State Dir
WALLET_STATE_DIR=./.wallet-state
