{
  "name": "@capacity-exchange/server",
  "version": "1.0.0",
  "description": "Capacity Exchange Server",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "prebuild": "bun run --filter '@capacity-exchange/midnight-core' build && bun run --filter '@capacity-exchange/midnight-node' build",
    "build": "tsc",
    "start": "bun dist/server.js",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist .sync_cache midnight-level-db .wallet-state",
    "test": "vitest run",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "run-servers": "bun scripts/run-servers.ts",
    "test:sponsor": "bun scripts/test-prove-and-sponsor.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1018.0",
    "@capacity-exchange/components": "1.0.0",
    "@capacity-exchange/midnight-core": "1.0.0",
    "@capacity-exchange/midnight-node": "1.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.4",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.1",
    "@midnight-ntwrk/midnight-js-types": "4.0.1",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "3.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sinclair/typebox": "^0.34.47",
    "cbor2": "^2.0.1",
    "dotenv": "17.2.3",
    "fastify": "5.6.2",
    "fastify-plugin": "^5.1.0",
    "lru-cache": "^11.2.7",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@midnight-ntwrk/wallet-sdk-abstractions": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-runtime": "1.0.2",
    "@midnight-ntwrk/wallet-sdk-shielded": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0",
    "@types/node": "22.10.7",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.17"
  }
}
