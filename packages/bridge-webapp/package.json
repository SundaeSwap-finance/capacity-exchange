{
  "name": "@capacity-exchange/bridge-webapp",
  "version": "1.0.0",
  "description": "Bridge Webapp — Cardano ↔ Midnight",
  "type": "module",
  "main": "index.js",
  "license": "ISC",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc && vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "copy-zk-assets": "mkdir -p public/midnight/vault/keys public/midnight/vault/zkir && cp -r ../bridge-contracts/vault/out/keys/* public/midnight/vault/keys/ && cp -r ../bridge-contracts/vault/out/zkir/* public/midnight/vault/zkir/"
  },
  "dependencies": {
    "@blaze-cardano/sdk": "^0.2.31",
    "@capacity-exchange/bridge-contracts": "1.0.0",
    "@capacity-exchange/components": "1.0.0",
    "@capacity-exchange/midnight-core": "1.0.0",
    "@midnight-ntwrk/compact-js": "2.5.0",
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.1",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "4.0.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.1",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.1",
    "@midnight-ntwrk/midnight-js-types": "4.0.1",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
