{
  "name": "@capacity-exchange/example-contracts",
  "version": "1.0.0",
  "description": "Example Midnight contracts for capacity exchange demos",
  "type": "module",
  "exports": {
    "./counter/out/contract/*": "./counter/out/contract/*",
    "./token-mint/out/contract/*": "./token-mint/out/contract/*"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "fix": "eslint src --fix && prettier --write src",
    "token-mint:e2e": "tsx src/token-mint/cli/e2e.ts",
    "counter:e2e": "tsx src/counter/cli/e2e.ts"
  },
  "keywords": [
    "midnight",
    "compact",
    "smart-contracts",
    "zero-knowledge"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.11.0-rc.1",
    "@midnight-ntwrk/ledger-v6": "6.1.0-alpha.6",
    "@midnight-ntwrk/midnight-js-contracts": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-types": "3.0.0-alpha.11",
    "@midnight-ntwrk/onchain-runtime-v1": "1.0.0-alpha.5",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.0.0-beta.9",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "1.0.0-beta.11",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.0-beta.7",
    "@scure/bip32": "2.0.1",
    "@scure/bip39": "^2.0.1",
    "cbor2": "^2.0.1",
    "commander": "^14.0.2",
    "dotenv": "17.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@midnight-ntwrk/wallet-sdk-facade": "1.0.0-beta.12",
    "@midnight-ntwrk/wallet-sdk-runtime": "1.0.0-beta.10",
    "@midnight-ntwrk/wallet-sdk-shielded": "1.0.0-beta.12",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "1.0.0-beta.14",
    "@types/node": "22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@midnight-ntwrk/wallet-sdk-runtime": "1.0.0-beta.10",
    "@midnight-ntwrk/wallet-sdk-shielded": "1.0.0-beta.12",
    "whatwg-url": "14.1.1",
    "tr46": "5.1.1"
  }
