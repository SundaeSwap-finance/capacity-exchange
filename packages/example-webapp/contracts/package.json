{
  "name": "@capacity-exchange/example-contracts",
  "version": "1.0.0",
  "description": "Example Midnight contracts for capacity exchange demos",
  "type": "module",
  "exports": {
    "./counter/out/contract/*": "./counter/out/contract/*",
    "./token-mint/out/contract/*": "./token-mint/out/contract/*"
  },
  "scripts": {
    "clean": "rm -rf counter/out token-mint/out node_modules .midnight-private-state .wallet-state .contracts.*.json",
    "compile:counter": "\"$COMPACTC\" counter/counter.compact counter/out",
    "compile:token-mint": "\"$COMPACTC\" token-mint/vault.compact token-mint/out",
    "compile": "npm run compile:counter && npm run compile:token-mint",
    "build": "tsc --noEmit",
    "balances": "tsx src/wallet/cli/balances.ts",
    "counter:e2e": "tsx src/counter/cli/e2e.ts",
    "counter:deploy": "tsx src/counter/cli/deploy.ts",
    "counter:increment": "tsx src/counter/cli/increment.ts",
    "counter:query": "tsx src/counter/cli/query.ts",
    "token-mint:e2e": "tsx src/token-mint/cli/e2e.ts",
    "token-mint:deploy": "tsx src/token-mint/cli/deploy.ts",
    "token-mint:mint": "tsx src/token-mint/cli/mint.ts",
    "token-mint:verify": "tsx src/token-mint/cli/verify.ts",
    "deploy-all": "tsx src/deploy-all.ts"
  },
  "keywords": [
    "midnight",
    "compact",
    "smart-contracts",
    "zero-knowledge"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacity-exchange/core": "1.0.0",
    "@midnight-ntwrk/compact-js": "2.4.0",
    "@midnight-ntwrk/compact-runtime": "^0.14.0",
    "@midnight-ntwrk/ledger-v7": "7.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "3.0.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-types": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "1.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.0",
    "@scure/bip32": "2.0.1",
    "@scure/bip39": "^2.0.1",
    "cbor2": "^2.0.1",
    "commander": "^14.0.2",
    "dotenv": "17.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@midnight-ntwrk/wallet-sdk-facade": "1.0.0",
    "@midnight-ntwrk/wallet-sdk-runtime": "1.0.0",
    "@midnight-ntwrk/wallet-sdk-shielded": "1.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "1.0.0",
    "@types/node": "22.10.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
