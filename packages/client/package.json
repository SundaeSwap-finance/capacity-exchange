{
  "name": "@capacity-exchange/client",
  "version": "1.0.0",
  "description": "Capacity Exchange Client",
  "main": "generated/dist/index.js",
  "module": "generated/dist/index.js",
  "types": "generated/dist/index.d.ts",
  "files": [
    "generated/dist"
  ],
  "exports": {
    ".": {
      "import": "./generated/dist/index.js",
      "require": "./generated/dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf generated/dist generated/tsconfig.tsbuildinfo",
    "regenerate-client": "openapi-generator-cli generate -i openapi.json -g typescript-fetch -o generated --additional-properties=supportsES6=true",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "es6-promise": "^4.2.4",
    "whatwg-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.28.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
